import json

# Путь к sbomy
file_path = 'sbom.json'

def remove_duplicates_from_dependson(data):
    if isinstance(data, dict):
        for key, value in data.items():
            if key == 'dependsOn' and isinstance(value, list):
                data[key] = list(set(value))
            elif isinstance(value, (dict, list)):
                remove_duplicates_from_dependson(value)
    elif isinstance(data, list):
        for item in data:
            if isinstance(item, (dict, list)):
                remove_duplicates_from_dependson(item)

try:
    with open(file_path, 'r', encoding='utf-8') as f:
        data = json.load(f)
except FileNotFoundError:
    print(f"File {file_path} not found.")
    exit(1)
except json.JSONDecodeError:
    print(f"Error parsing {file_path}.")
    exit(1)

remove_duplicates_from_dependson(data)

with open(file_path, 'w', encoding='utf-8') as f:
    json.dump(data, f, ensure_ascii=False, indent=2)

print(f"Success.")

